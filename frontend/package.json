{
  "name": "vanguard-graph-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "tailwind": "tailwindcss -i app/tailwind-input.css -o app/tailwind.css",
    "tailwind:watch": "tailwindcss -i app/tailwind-input.css -o app/tailwind.css --watch",
    "dev:css": "tailwindcss -i app/tailwind-input.css -o app/tailwind.css",
    "dev": "npm run dev:css && next dev --port 3002",
    "dev:watch": "npm run tailwind:watch & next dev --port 3002",
    "build": "npm run dev:css && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-dropdown-menu": "^2",
    "@radix-ui/react-tabs": "^1",
    "@radix-ui/react-tooltip": "^1",
    "@tanstack/react-query": "^5",
    "axios": "^1",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "date-fns": "^3",
    "framer-motion": "^12",
    "lucide-react": "^0.383",
    "mime": "^4.1.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-countup": "^6",
    "react-dom": "19.2.4",
    "react-force-graph-2d": "^1",
    "react-hook-form": "^7",
    "recharts": "^2",
    "send": "^1.2.1",
    "tailwind-merge": "^2",
    "uuid": "^9",
    "zod": "^3",
    "zustand": "^4"
  },
  "devDependencies": {
    "@hookform/resolvers": "^3",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "^16.2.10"
  }
}
